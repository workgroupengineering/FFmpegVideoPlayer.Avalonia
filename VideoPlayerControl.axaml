<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Avalonia.FFmpegVideoPlayer"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="Avalonia.FFmpegVideoPlayer.VideoPlayerControl"
             x:Name="Root">

    <UserControl.Resources>
        <PathGeometry x:Key="PlayIcon" Figures="M 6,4 L 6,16 L 18,10 Z"/>
        <PathGeometry x:Key="PauseIcon" Figures="M 6,4 L 10,4 L 10,16 L 6,16 Z M 14,4 L 18,4 L 18,16 L 14,16 Z"/>
        <PathGeometry x:Key="StopIcon" Figures="M 6,6 L 18,6 L 18,18 L 6,18 Z"/>
        <PathGeometry x:Key="FolderOpenIcon" Figures="M 4,6 L 4,8 L 6,8 L 8,6 L 16,6 L 18,8 L 18,16 L 4,16 Z M 4,8 L 6,10 L 18,10 L 18,8 Z"/>
        <PathGeometry x:Key="VolumeHighIcon" Figures="M 5,6 L 5,14 L 9,14 L 13,18 L 13,2 L 9,6 Z M 15,8 A 2,2 0 0,1 15,12 M 17,6 A 3,3 0 0,1 17,14"/>
        <PathGeometry x:Key="VolumeOffIcon" Figures="M 5,6 L 5,14 L 9,14 L 13,18 L 13,2 L 9,6 Z M 15,5 L 19,9 M 15,9 L 19,5"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Icon-only button: transparent background, subtle hover -->
        <Style Selector="Button.iconButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="{Binding ButtonPadding, ElementName=Root}"/>
            <Setter Property="CornerRadius" Value="{Binding ButtonCornerRadius, ElementName=Root}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.iconButton:pointerover">
            <Setter Property="Background" Value="#18000000"/>
        </Style>
        <Style Selector="Button.iconButton:pressed">
            <Setter Property="Background" Value="#28000000"/>
        </Style>

        <!-- Legacy mediaButton style kept for backward compat -->
        <Style Selector="Button.mediaButton">
            <Setter Property="Background" Value="#e8e8e8"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#999999"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="{Binding ButtonPadding, ElementName=Root}"/>
            <Setter Property="CornerRadius" Value="{Binding ButtonCornerRadius, ElementName=Root}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.mediaButton:pointerover">
            <Setter Property="Background" Value="#d0d0d0"/>
            <Setter Property="BorderBrush" Value="#666666"/>
        </Style>
        <Style Selector="Button.mediaButton:pressed">
            <Setter Property="Background" Value="#c0c0c0"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto">
        <!-- Video View -->
        <Border Name="VideoBorder" Grid.Row="0" Background="{Binding VideoBackground, ElementName=Root}">
            <Image Name="VideoImage" Stretch="Uniform" />
        </Border>

        <!-- Controls Panel - single row: [Open] [Play] [Stop] | 00:00 [====seek====] 00:00 | [Vol] [==] -->
        <Border Name="ControlPanelBorder" Grid.Row="1" Background="White"
                Padding="{Binding ControlPanelPadding, ElementName=Root}">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">

                <!-- Open File Button -->
                <Button Name="OpenButton" Grid.Column="0" Margin="0,0,2,0"
                        Classes="iconButton" Click="OnOpenClick">
                    <Path Name="FolderIcon"
                          Width="{Binding IconSize, ElementName=Root}"
                          Height="{Binding IconSize, ElementName=Root}"
                          Stretch="Uniform" Fill="#333333"
                          Data="{StaticResource FolderOpenIcon}"/>
                </Button>

                <!-- Play/Pause Button -->
                <Button Name="PlayPauseButton" Grid.Column="1" Margin="0,0,2,0"
                        Classes="iconButton" Click="OnPlayPauseClick">
                    <Path Name="PlayPauseIcon"
                          Width="{Binding IconSize, ElementName=Root}"
                          Height="{Binding IconSize, ElementName=Root}"
                          Stretch="Uniform" Fill="#333333"
                          Data="{StaticResource PlayIcon}"/>
                </Button>

                <!-- Stop Button -->
                <Button Name="StopButton" Grid.Column="2" Margin="0,0,6,0"
                        Classes="iconButton" Click="OnStopClick">
                    <Path Name="StopIcon"
                          Width="{Binding IconSize, ElementName=Root}"
                          Height="{Binding IconSize, ElementName=Root}"
                          Stretch="Uniform" Fill="#333333"
                          Data="{StaticResource StopIcon}"/>
                </Button>

                <!-- Current Time -->
                <TextBlock Name="CurrentTimeText" Grid.Column="3"
                           Text="00:00"
                           VerticalAlignment="Center" Margin="0,0,4,0"
                           FontSize="{Binding ControlFontSize, ElementName=Root}"/>

                <!-- Seek Bar -->
                <Slider Name="SeekBar" Grid.Column="4"
                        Minimum="0" Maximum="100" Value="0"
                        VerticalAlignment="Center" Margin="0,0,4,0"/>

                <!-- Total Time -->
                <TextBlock Name="TotalTimeText" Grid.Column="5"
                           Text="00:00"
                           VerticalAlignment="Center" Margin="0,0,6,0"
                           FontSize="{Binding ControlFontSize, ElementName=Root}"/>

                <!-- Volume Icon -->
                <Button Name="VolumeButton" Grid.Column="6" Margin="0,0,2,0"
                        Classes="iconButton" Click="OnMuteClick">
                    <Path Name="VolumeIcon"
                          Width="{Binding IconSize, ElementName=Root}"
                          Height="{Binding IconSize, ElementName=Root}"
                          Stretch="Uniform" Fill="#333333"
                          Data="{StaticResource VolumeHighIcon}"/>
                </Button>

                <!-- Volume Slider -->
                <Slider Name="VolumeSlider" Grid.Column="7"
                        Width="60" Minimum="0" Maximum="100" Value="100"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
