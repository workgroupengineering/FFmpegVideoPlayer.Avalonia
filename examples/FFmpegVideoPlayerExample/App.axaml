<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FFmpegVideoPlayerExample.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
        <!-- Icons are provided by default using standard Avalonia shapes -->
        <!-- To use custom icons, set VideoPlayerControl.IconProvider property -->
    </Application.Styles>
</Application>
